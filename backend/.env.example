DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interview_platform?schema=public"
PORT=3000

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=24h

# LLM provider: omlx | gemini | openai | cursor-acp
LLM_PROVIDER=omlx

# --- omlx (локальна модель: omlx serve --port 8000) ---
OMLX_BASE_URL=http://127.0.0.1:8000
OMLX_MODEL=Qwen2.5-7B-Instruct-4bit
# OMLX_API_KEY=  # required if omlx auth is enabled (see ~/.omlx/settings.json)

# --- gemini (хмарна модель: встанови LLM_PROVIDER=gemini) ---
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-2.0-flash

# --- openai (розкоментуй і встанови LLM_PROVIDER=openai) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- cursor-acp (uses local Cursor CLI login; no token required in .env) ---
# LLM_PROVIDER=cursor-acp
# CURSOR_ACP_EXECUTABLE=agent
# CURSOR_ACP_STARTUP_TIMEOUT_MS=15000
# CURSOR_ACP_PROMPT_TIMEOUT_MS=120000
# CURSOR_ACP_SHUTDOWN_GRACE_MS=5000
# CURSOR_ACP_TERMINATE_GRACE_MS=2000
# CURSOR_ACP_MAX_SESSIONS=100
# CURSOR_ACP_MAX_LINE_BYTES=1048576
