{
  "name": "interview-platform",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=backend & npm run dev --workspace=frontend",
    "mcp:browser": "playwright-mcp --port 8931",
    "build": "npm run --workspaces build",
    "lint": "npm run --workspaces lint",
    "ci:bootstrap": "npm run lint && npm run build"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.78",
    "playwright": "^1.61.1"
  }
}
